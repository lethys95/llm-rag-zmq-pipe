# Environment Variables for LLM RAG Response Pipe
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# OpenRouter API Key (required for remote LLM inference)
OPENROUTER_API_KEY=your-api-key-here

# =============================================================================
# Optional Configuration
# =============================================================================

# ZMQ Endpoints
LLM_RAG_PIPE_INPUT_ADDRESS=tcp://*:5555
LLM_RAG_PIPE_OUTPUT_ADDRESS=tcp://*:5556

# Logging
LOG_LEVEL=INFO

# Configuration File (optional - if using custom config.json)
CONFIG_FILE=

# GPU Configuration (for GPU variant only)
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# Qdrant Configuration (usually default is fine)
# =============================================================================

# Qdrant URL (default: http://qdrant:6333 inside Docker network)
# QDRANT_URL=http://qdrant:6333

# =============================================================================
# Advanced Options
# =============================================================================

# Override specific models (optional)
# PRIMARY_LLM_MODEL=anthropic/claude-3.5-sonnet
# SENTIMENT_LLM_MODEL=google/gemini-flash-1.5
# INTERPRETER_LLM_MODEL=anthropic/claude-3.5-sonnet

# Feature toggles (optional)
# ENABLE_SENTIMENT_ANALYSIS=true
# ENABLE_CONTEXT_INTERPRETER=true

# Memory decay parameters (optional)
# MEMORY_DECAY_HALF_LIFE_DAYS=7.0
# MEMORY_DECAY_CHRONO_WEIGHT=1.5
# MEMORY_DECAY_MAX_DOCUMENTS=10
